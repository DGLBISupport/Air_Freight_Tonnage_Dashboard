# Environment Variables Template for Cloud Run Deployment
# Copy these and fill in the values, then set them in Cloud Run

# ========================================
# AZURE EMAIL CONFIGURATION (Required for /api/send-report)
# ========================================
MAIL_AZURE_TENANT_ID=your-azure-tenant-id-here
MAIL_AZURE_CLIENT_ID=your-app-client-id-here
MAIL_AZURE_CLIENT_SECRET=your-app-client-secret-here
SENDER_EMAIL=sender@company.com

# ========================================
# DATABASE CONFIGURATION (Required for /api/send-report)
# ========================================
DB_SERVER=your-sql-server.database.windows.net
DB_USER=sqluser@yourdomain
DB_PASSWORD=your-secure-password-here

# Optional: On-premises API endpoint (has default value)
# ONPREM_API_URL=https://survey.dartglobal.com/chatbot/v1.0/data

# ========================================
# EMAIL RECIPIENTS (Required for scheduled reports)
# ========================================
RECIPIENT_EMAILS=shashini.hq@dartglobal.com,other@dartglobal.com

# Optional: Station-specific recipients
# RECIPIENTS_CMB=colombo-team@dartglobal.com
# RECIPIENTS_IND=india-team@dartglobal.com
# RECIPIENTS_VNM=vietnam-team@dartglobal.com
# RECIPIENTS_DAC=bangladesh-team@dartglobal.com
# RECIPIENTS_PKI=pakistan-team@dartglobal.com
# RECIPIENTS_NYC=us-team@dartglobal.com
# RECIPIENTS_OTHER=corporate-team@dartglobal.com

# ========================================
# HOW TO SET THESE IN CLOUD RUN
# ========================================

# METHOD 1: Cloud Console
# 1. Go to Cloud Run console
# 2. Click your service name
# 3. Click "Edit & Deploy New Revision"
# 4. Scroll to "Runtime Settings"
# 5. Add each variable under "Runtime environment variables"
# 6. Click Deploy

# METHOD 2: gcloud CLI (recommended for sensitive values)
# gcloud run deploy tonnage-report \
#   --region us-central1 \
#   --set-env-vars=MAIL_AZURE_TENANT_ID=xxx \
#   --set-env-vars=MAIL_AZURE_CLIENT_ID=xxx \
#   --set-env-vars=MAIL_AZURE_CLIENT_SECRET=xxx \
#   --set-env-vars=SENDER_EMAIL=xxx \
#   --set-env-vars=DB_SERVER=xxx \
#   --set-env-vars=DB_USER=xxx \
#   --set-env-vars=DB_PASSWORD=xxx

# ========================================
# SECURITY NOTE: Use Cloud Secret Manager
# ========================================
# For sensitive values like client secrets and passwords:
#
# 1. Create a secret:
#    gcloud secrets create MAIL_CLIENT_SECRET --data-file=- <<< "your-secret-value"
#
# 2. Grant Cloud Run service account access:
#    gcloud secrets add-iam-policy-binding MAIL_CLIENT_SECRET \
#      --member=serviceAccount:PROJECT-ID@appspot.gserviceaccount.com \
#      --role=roles/secretmanager.secretAccessor
#
# 3. Reference it in deployment:
#    gcloud run deploy tonnage-report \
#      --set-env-vars=MAIL_AZURE_CLIENT_SECRET=secret:MAIL_CLIENT_SECRET:latest

# ========================================
# TROUBLESHOOTING
# ========================================
# 503 Error? Check:
# 1. All required variables are set: MAIL_AZURE_TENANT_ID, MAIL_AZURE_CLIENT_ID, 
#    MAIL_AZURE_CLIENT_SECRET, SENDER_EMAIL, DB_SERVER, DB_USER, DB_PASSWORD
# 2. Values are correct (no typos)
# 3. For SQL Server: Whitelist Cloud Run IP in SQL Server firewall
# 4. Check Cloud Run logs: gcloud run services logs read tonnage-report --region us-central1
